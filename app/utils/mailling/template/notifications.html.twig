<!DOCTYPE html>
		<html>
			<head>
				<meta charset="UTF-8">
				<title>
					{{ subject }}
				</title>
			</head>
			<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
				<div style="max-width: 600px; margin: 0 auto;">
					{% if logo %}
						<img src="{{ logo }}" alt="Logo" style="max-width: 200px; margin-bottom: 30px;">
					{% endif %}

					<h1 style="color: #2c3e50; margin-bottom: 20px;">
						{{ subject }}
					</h1>

					<p>
						Bonjour
						{{ prenom }}
						{{ nom }}
						,
					</p>

					{{ message|raw }}

					{% if url %}
						<p style="margin: 30px 0;">
							<a href="{{ url }}" style="background: #3498db; color: white; padding: 12px 24px; text-decoration: none; border-radius: 5px; display: inline-block;">
								{{ button_text|default('Voir plus') }}
							</a>
						</p>
					{% endif %}

					<hr style="margin: 40px 0; border: none; border-top: 1px solid #eee;">

					<p style="color: #7f8c8d; font-size: 14px;">
						Cet email a été envoyé automatiquement.
						<br>
						Si vous n'êtes pas l'utilisateur concerné, merci d'ignorer ce message.
					</p>

					{% if contact %}
						<p style="color: #7f8c8d; font-size: 14px;">
							Besoin d'aide ?
							<a href="{{ contact }}">
								Contactez-nous
							</a>
						</p>
					{% endif %}
				</div>
			</body>
		</html>
